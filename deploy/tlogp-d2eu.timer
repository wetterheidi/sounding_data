# systemd-Timer für ICON-D2 + ICON-EU
# Läufe: 00,03,06,09,12,15,18,21 UTC → DWD-Verfügbarkeit ~2h → Trigger 2h15m danach
# Einzuspielen nach: /etc/systemd/system/tlogp-d2eu.timer
# Aktivieren mit:
#   systemctl daemon-reload
#   systemctl enable --now tlogp-d2eu.timer

[Unit]
Description=TLogP Download Timer – ICON-D2 + ICON-EU (alle 3h)

[Timer]
OnCalendar=*-*-* 02,05,08,11,14,17,20,23:15:00
AccuracySec=30s
Persistent=true

[Install]
WantedBy=timers.target
